# OpenAI-compatible LLM endpoint for local evaluation.
# Copy this file to .env locally if desired, then export/load the variables
# before running run.py. Do not commit real API keys.

LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=replace-with-your-api-key
LLM_MODEL=qwen3-8b
LLM_ENABLE_THINKING=false
